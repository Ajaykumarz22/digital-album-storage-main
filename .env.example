# Copy to .env.local on the server and fill in real values. NEVER commit .env.local.
# For production, values are the SAME as your local .env.local EXCEPT Clerk uses
# the production keys (pk_live_/sk_live_).

# MongoDB Atlas
MONGODB_URI=

# iDrive e2 — HOT storage (Temporary + Regular tiers)
S3_ENDPOINT=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=

# AWS S3 Glacier Deep Archive — COLD storage (Mumbai)
AWS_REGION=ap-south-1
AWS_S3_ARCHIVE_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Clerk — use PRODUCTION keys (pk_live_/sk_live_) for the live domain
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/setup
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/setup

# Redis — local on the same EC2 box
REDIS_URL=redis://127.0.0.1:6379
